<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog">
    <defaultcontrol always="true">1</defaultcontrol>

    <controls>
        <!-- Schwarzer Vollbild-Hintergrund -->
        <control type="image" id="9000">
            <posx>0</posx>
            <posy>0</posy>
            <width>1920</width>
            <height>1080</height>
            <texture>$INFO[Window.Property(black_background)]</texture>
        </control>

        <!-- Poster links -->
        <control type="image" id="100">
            <posx>80</posx>
            <posy>100</posy>
            <width>500</width>
            <height>750</height>
            <aspectratio>keep</aspectratio>
        </control>

        <!-- Titel rechts -->
        <control type="label" id="200">
            <posx>650</posx>
            <posy>90</posy>
            <width>1170</width>
            <height>100</height>
            <font>font30</font>
            <textcolor>FFFFFFFF</textcolor>
            <wrapmultiline>true</wrapmultiline>
            <align>left</align>
            <aligny>center</aligny>
        </control>

        <!-- Beschreibung rechts -->
        <control type="textbox" id="300">
            <posx>650</posx>
            <posy>220</posy>
            <width>1170</width>
            <height>590</height>
            <font>font14</font>
            <textcolor>FFEEEEEE</textcolor>
            <wrapmultiline>true</wrapmultiline>
            <autoscroll time="3000" delay="4000" repeat="5000">true</autoscroll>
        </control>

        <!-- Schließen-Button -->
        <control type="button" id="1">
            <posx>650</posx>
            <posy>850</posy>
            <width>400</width>
            <height>70</height>
            <label>Schließen</label>
            <font>font14</font>
            <align>center</align>
        </control>
    </controls>
</window>